{
  "appId": "com.guide-ide.desktop",
  "productName": "guIDE",
  "copyright": "Copyright © 2026 GraySoft LLC",
  "electronVersion": "22.3.27",
  "electronDist": "build/electron-legacy-dist",
  "directories": {
    "output": "dist-electron"
  },
  "files": [
    "*.js",
    "*.json",
    "server/**/*",
    "pipeline/**/*",
    "tools/**/*",
    "chatWrappers/**/*",
    "frontend/dist/**/*",
    "node_modules/**/*",
    "build/**/*",
    "!node_modules/.cache/**",
    "!node_modules/@node-llama-cpp/**",
    "!node_modules/playwright/**",
    "!node_modules/playwright-core/**",
    "!frontend/node_modules/**",
    "!**/*.map",
    "!**/*.ts",
    "!**/test/**",
    "!**/tests/**",
    "!**/spec/**",
    "!**/.git/**"
  ],
  "asar": false,
  "linux": {
    "icon": "build/icon.png",
    "target": [
      { "target": "AppImage", "arch": ["x64"] }
    ],
    "artifactName": "guIDE-${version}-cuda-legacy-linux-x64.${ext}",
    "category": "Development"
  }
}
