{
  "appId": "com.guide-ide.desktop",
  "productName": "guIDE",
  "copyright": "Copyright © 2026 GraySoft LLC",
  "directories": {
    "output": "dist-electron"
  },
  "files": [
    "*.js",
    "*.json",
    "server/**/*",
    "pipeline/**/*",
    "tools/**/*",
    "browserBackends/**/*",
    "chatWrappers/**/*",
    "frontend/dist/**/*",
    "node_modules/**/*",
    "build/**/*",
    "!node_modules/.cache/**",
    "!node_modules/@node-llama-cpp/win-arm64/**",
    "!node_modules/@node-llama-cpp/win-x64-vulkan/**",
    "!node_modules/@node-llama-cpp/win-x64-cuda-ext/**",
    "!node_modules/@node-llama-cpp/linux-*/**",
    "!node_modules/@node-llama-cpp/mac-*/**",
    "!frontend/node_modules/**",
    "!**/*.map",
    "!**/*.ts",
    "!**/test/**",
    "!**/tests/**",
    "!**/spec/**",
    "!**/.git/**"
  ],
  "win": {
    "icon": "build/icon.ico",
    "sign": false,
    "artifactName": "guIDE-${version}-cuda-x64.${ext}",
    "target": [
      {
        "target": "zip",
        "arch": ["x64"]
      }
    ]
  },
  "asar": false,
  "extraFiles": [
    {
      "from": "scripts/Install-guIDE-CUDA.ps1",
      "to": "Install guIDE.ps1"
    }
  ],
  "extraResources": [
    {
      "from": "resources/install-variant-cuda.json",
      "to": "install-variant.json"
    },
    {
      "from": "playwright-browsers",
      "to": "playwright-browsers",
      "filter": ["**/*"]
    },
    {
      "from": "resources/whisper",
      "to": "whisper",
      "filter": ["**/*"]
    },
    {
      "from": "resources/sd-cpp/win-x64-cuda",
      "to": "sd-cpp",
      "filter": ["**/*"]
    },
    {
      "from": "resources/media-assets",
      "to": "media-assets",
      "filter": ["**/*"]
    }
  ],
  "mac": {
    "icon": "build/icon.icns",
    "target": [
      { "target": "dmg", "arch": ["x64", "arm64"] }
    ],
    "artifactName": "guIDE-${version}-cuda-mac-${arch}.${ext}"
  },
  "linux": {
    "icon": "build/icon.png",
    "target": [
      { "target": "AppImage", "arch": ["x64"] }
    ],
    "artifactName": "guIDE-${version}-cuda-linux-x64.${ext}",
    "category": "Development"
  },
  "publish": {
    "provider": "github",
    "owner": "FileShot",
    "repo": "guide-3.0",
    "channel": "cuda"
  }
}
