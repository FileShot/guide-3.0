+      const MAX_RESULTS = 500;
+      const BINARY_EXTS = new Set(['.png','.jpg','.jpeg','.gif','.webp','.bmp','.ico','.svg','.woff','.woff2','.ttf','.eot','.mp3','.mp4','.wav','.ogg','.zip','.tar','.gz','.rar','.7z','.pdf','.exe','.dll','.so','.dylib','.o','.pyc','.class','.gguf','.bin','.dat','.db','.sqlite','.lock']);
